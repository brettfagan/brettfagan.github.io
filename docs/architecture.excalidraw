    {
      "id": "t-edge-content",
      "type": "text",
      "x": 782, "y": 906,
      "width": 296, "height": 350,
      "angle": 0,
      "strokeColor": "#92400e", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "roundness": null,
      "seed": 3009, "version": 1, "isDeleted": false,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "plaid-fetch\n  — full history (offset pagination)\n  — incremental sync cursor\n  — returns transactions + accounts\n\nsend-invite\n  — create partner_invites row\n  — send email via Resend API\n  — auto-generated token, 48h TTL\n\naccept-invite\n  — validate token + email match\n  — create partner_access row\n  — uses admin client (bypass RLS)\n\nAuth: user JWT → scoped client\nAdmin: SERVICE_ROLE_KEY\nSecrets: Supabase dashboard only",
      "fontSize": 13, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "plaid-fetch\n  — full history (offset pagination)\n  — incremental sync cursor\n  — returns transactions + accounts\n\nsend-invite\n  — create partner_invites row\n  — send email via Resend API\n  — auto-generated token, 48h TTL\n\naccept-invite\n  — validate token + email match\n  — create partner_access row\n  — uses admin client (bypass RLS)\n\nAuth: user JWT → scoped client\nAdmin: SERVICE_ROLE_KEY\nSecrets: Supabase dashboard only",
      "lineHeight": 1.4, "baseline": 11
    },

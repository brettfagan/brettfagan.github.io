    {
      "id": "t-supabase-db-content",
      "type": "text",
      "x": 377, "y": 906,
      "width": 346, "height": 350,
      "angle": 0,
      "strokeColor": "#166534", "backgroundColor": "transparent",
      "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid",
      "roughness": 1, "opacity": 100,
      "groupIds": [], "frameId": null, "roundness": null,
      "seed": 3006, "version": 1, "isDeleted": false,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "Tables (all RLS by user_id):\n\nimported_transactions\n  — main store (source, date, merchant,\n    amount, cat, cat_detail)\n\ncategories  — user category config\ncat_rules   — regex auto-categorization\ndetail_labels — Plaid detail overrides\nplaid_connections — access tokens\npartner_invites — invite tokens (48h)\npartner_access  — active partner links\nbudget_items    — monthly targets\n\nProject ID: ufnpwuygtgfdruvxadpm",
      "fontSize": 13, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "Tables (all RLS by user_id):\n\nimported_transactions\n  — main store (source, date, merchant,\n    amount, cat, cat_detail)\n\ncategories  — user category config\ncat_rules   — regex auto-categorization\ndetail_labels — Plaid detail overrides\nplaid_connections — access tokens\npartner_invites — invite tokens (48h)\npartner_access  — active partner links\nbudget_items    — monthly targets\n\nProject ID: ufnpwuygtgfdruvxadpm",
      "lineHeight": 1.4, "baseline": 11
    },

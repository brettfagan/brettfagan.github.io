      "seed": 3003, "version": 1, "isDeleted": false,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "Google OAuth provider\nJWT session tokens\n\nMulti-tab session guard\n  • heartbeat (localStorage)\n  • BroadcastChannel\n  • 15 min inactivity timeout\n\nPartner role detection\n  • role: 'primary' | 'linked'\n  • effectiveUserId",
      "fontSize": 13, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "Google OAuth provider\nJWT session tokens\n\nMulti-tab session guard\n  • heartbeat (localStorage)\n  • BroadcastChannel\n  • 15 min inactivity timeout\n\nPartner role detection\n  • role: 'primary' | 'linked'\n  • effectiveUserId",
      "lineHeight": 1.4, "baseline": 11

      "seed": 3012, "version": 1, "isDeleted": false,
      "boundElements": [], "updated": 1, "link": null, "locked": false,
      "text": "Plaid API\n  — /transactions/get\n    (full history, offset)\n  — /transactions/sync\n    (incremental cursor)\n  — /link/token/create\n  — /item/public_token/exchange\n  — returns personal_finance_\n    category (primary + detailed)\n\nResend\n  — email delivery\n  — partner invite emails\n  — API key in Supabase secrets",
      "fontSize": 13, "fontFamily": 2,
      "textAlign": "left", "verticalAlign": "top",
      "containerId": null, "originalText": "Plaid API\n  — /transactions/get\n    (full history, offset)\n  — /transactions/sync\n    (incremental cursor)\n  — /link/token/create\n  — /item/public_token/exchange\n  — returns personal_finance_\n    category (primary + detailed)\n\nResend\n  — email delivery\n  — partner invite emails\n  — API key in Supabase secrets",
      "lineHeight": 1.4, "baseline": 11
    },
